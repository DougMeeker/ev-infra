# ── Microsoft Entra ID (Azure AD) Authentication ─────────────────────
# Leave blank / unset to run without authentication (local dev)

# Application (client) ID from your Entra ID app registration
REACT_APP_AZURE_AD_CLIENT_ID=

# Directory (tenant) ID – Caltrans tenant
REACT_APP_AZURE_AD_TENANT_ID=

# (Optional) Override redirect URI (defaults to window.location.origin)
# REACT_APP_AZURE_AD_REDIRECT_URI=http://localhost:3000

# (Optional) Custom API scope – defaults to api://<client_id>/.default
# REACT_APP_AZURE_AD_SCOPE=

# ── API Base URL Override ────────────────────────────────────────────
# REACT_APP_API_BASE=http://localhost:5000/api
