# ── OIDC Authentication (Authelia or any OIDC-compliant provider) ─────
# Leave both blank / unset to run without authentication (local dev)

# Base URL of the OIDC issuer (e.g. https://auth.example.com)
REACT_APP_OIDC_AUTHORITY=https://svgc32zevi.dot.ca.gov/authelia

# Client ID registered with the OIDC provider
REACT_APP_OIDC_CLIENT_ID=evinfra

# (Optional) Override redirect URI after login (defaults to window.location.origin)
# REACT_APP_OIDC_REDIRECT_URI=http://localhost:3000

# (Optional) Space-separated scopes (defaults to "openid profile email")
# REACT_APP_OIDC_SCOPE=openid profile email

# ── API Base URL Override ────────────────────────────────────────────
# REACT_APP_API_BASE=http://localhost:5000/api
