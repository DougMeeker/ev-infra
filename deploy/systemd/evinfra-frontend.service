[Unit]
Description=EV Infra Frontend (static server via serve)
After=network.target

[Service]
Type=simple
User=evinfra
Group=evinfra
WorkingDirectory=/opt/evinfra/frontend
# Serve the already-built static files from /opt/evinfra/frontend/build on localhost:3000
ExecStart=/usr/bin/npx serve -s build -l 127.0.0.1:3000
Restart=on-failure
RestartSec=5
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
