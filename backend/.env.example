# ── OIDC Authentication (Authelia or any OIDC-compliant provider) ─────
# Set to "true" to enforce JWT validation on all /api/ routes.
# Leave "false" for local development without an OIDC server.
OIDC_ENABLED=false

# Base URL of the OIDC issuer (e.g. https://auth.example.com)
OIDC_ISSUER=https://svgc32zevi.dot.ca.gov/authelia

# Client ID registered with the OIDC provider
OIDC_CLIENT_ID=evinfra

# (Optional) Override audience if different from client ID
# OIDC_AUDIENCE=

# (Optional) Override the JWKS URI (auto-derived as <OIDC_ISSUER>/.well-known/jwks.json)
# OIDC_JWKS_URI=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///evinfra.db

# ── File Uploads ─────────────────────────────────────────────────────
# UPLOAD_FOLDER=./uploads
# MAX_CONTENT_LENGTH=104857600
# STORAGE_PROVIDER=local

# ── MCP Knowledge Base Sync ─────────────────────────────────────────
# Set MCP_SYNC_ENABLED=true to push site/project/priority documents to the
# pgvector-api for semantic search via VS Code Copilot / MCP tools.
# Leave false (default) for zero performance impact when MCP is not in use.
MCP_SYNC_ENABLED=false

# Base URL of the pgvector-api companion service
MCP_PGVECTOR_URL=http://127.0.0.1:8000

# API key for pgvector-api authentication (leave blank if auth not configured)
MCP_API_KEY=

# ── S3 / MinIO ──────────────────────────────────────────────────────
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=evinfra-uploads
