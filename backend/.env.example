# ── Microsoft Entra ID (Azure AD) Authentication ─────────────────────
# Set to "true" to enforce JWT validation on all /api/ routes.
# Leave "false" for local development without Azure setup.
AZURE_AD_ENABLED=false

# Directory (tenant) ID – your Caltrans Entra ID tenant
AZURE_AD_TENANT_ID=your-tenant-id-here

# Application (client) ID registered in Entra ID
AZURE_AD_CLIENT_ID=your-client-id-here

# (Optional) Override audience if different from client ID
# AZURE_AD_AUDIENCE=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///evinfra.db

# ── File Uploads ─────────────────────────────────────────────────────
# UPLOAD_FOLDER=./uploads
# MAX_CONTENT_LENGTH=104857600
# STORAGE_PROVIDER=local

# ── S3 / MinIO ──────────────────────────────────────────────────────
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=evinfra-uploads
